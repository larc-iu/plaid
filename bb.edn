{:min-bb-version "1.0.0"
 ;; The build/test pipeline logic lives in bb/pipeline.clj (helpers can't be
 ;; shared via :init — bb analyzes task bodies before :init runs).
 :paths ["bb"]
 :tasks
 {test
  {:doc "Run the full Clojure test suite (plaid-core) — the same gate release.yml runs before building."
   :requires ([pipeline :as pl])
   :task (pl/run-tests!)}

  build
  {:doc "Build ALL release artifacts locally, like release.yml's build job (NO publishing). Usage: bb build [version] [--no-smoke] [--skip-clients]. version defaults to 0.0.0-alpha.0. Produces dist-artifacts/ (uberjar with the UD+IGT SPAs + services bundled, npm .tgz, Python sdist+wheel) and boot-smoke-tests the jar on :8080. Prereqs: Node >= 20 active (e.g. `nvm use 24.1.0`); for the Python client, the mamba base env active (`mamba activate base`) — or pass --skip-clients."
   :requires ([pipeline :as pl])
   :task (pl/build-artifacts! (pl/parse-build-args *command-line-args*))}

  ci
  {:doc "Run the whole non-publishing release pipeline locally: the test gate, then build all artifacts. Usage: bb ci [version] [--no-smoke] [--skip-clients]."
   :requires ([pipeline :as pl])
   :task (do (pl/run-tests!)
             (pl/build-artifacts! (pl/parse-build-args *command-line-args*)))}

  docs
  {:doc "Build the documentation site locally into _site/ (mirrors .github/workflows/docs.yml — index/manual/query/dev + the UD & IGT guides via Asciidoctor, plus the JS/Py API references best-effort via node). No publishing; open _site/index.html to preview. Prereq: `gem install asciidoctor coderay`."
   :requires ([pipeline :as pl])
   :task (pl/build-docs!)}

  clean
  {:doc "Remove local build outputs: dist-artifacts/, the _site/ docs preview, the bundled SPAs/services/version.edn under plaid-core/resources, built jars, and the SPA dist/ dirs."
   :requires ([pipeline :as pl])
   :task (pl/clean!)}

  release
  {:doc "Cut a release. Usage: bb release 0.2.0-alpha.1  — validates a clean tree on master, tags vX.Y.Z, and pushes. The release.yml workflow then tests, builds, and publishes everything. The git tag is the sole source of truth for the version."
   :requires ([clojure.string :as str])
   :task
   (let [version (first *command-line-args*)
         tag     (str "v" version)
         fail    (fn [msg] (binding [*out* *err*] (println "✗" msg)) (System/exit 1))
         git-out (fn [& args]
                   (str/trim (:out (apply shell {:out :string} "git" args))))]
     (when-not version
       (fail "Usage: bb release <version>   e.g. bb release 0.2.0-alpha.1"))
     ;; Version shape: X.Y.Z, optionally -alpha.N / -beta.N / -rc.N (lock-step
     ;; alpha scheme — keep it identical to what release.yml expects to parse).
     (when-not (re-matches (re-pattern "\\d+\\.\\d+\\.\\d+(-(?:alpha|beta|rc)\\.\\d+)?") version)
       (fail (str "'" version "' is not X.Y.Z or X.Y.Z-(alpha|beta|rc).N")))
     ;; Must be on master (releases cut from master per repo convention).
     (let [branch (git-out "rev-parse" "--abbrev-ref" "HEAD")]
       (when-not (= branch "master")
         (fail (str "on branch '" branch "', not master"))))
     ;; Working tree must be clean.
     (when-not (str/blank? (git-out "status" "--porcelain"))
       (fail "working tree is not clean — commit or stash first"))
     ;; Tag must not already exist (versions are immutable once published).
     (let [{:keys [exit]} (shell {:continue true :out :string :err :string}
                                 "git" "rev-parse" "--verify" "--quiet" tag)]
       (when (zero? exit)
         (fail (str "tag " tag " already exists"))))
     ;; Warn if local master is behind/ahead of origin (non-fatal).
     (shell {:continue true} "git" "fetch" "--quiet" "origin" "master")
     (let [local  (git-out "rev-parse" "HEAD")
           remote (git-out "rev-parse" "origin/master")]
       (when (not= local remote)
         (binding [*out* *err*]
           (println "⚠ local master differs from origin/master — the tag will point at your local HEAD."))))
     (println (str "→ tagging " tag " and pushing…"))
     (shell "git" "tag" "-a" tag "-m" (str "Release " tag))
     (shell "git" "push" "origin" tag)
     (println (str "✓ pushed " tag))
     (println "  Watch the release: gh run watch   (or the repo's Actions tab)"))}}}
